# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# ─── EMAIL (Gmail) ─────────────────────────────────────────────
# Used for order confirmation emails sent to customers and the restaurant.
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx   # Google App Password (NOT your real password)
EMAIL_TO=soukelbey2montagnes@gmail.com

# ─── STRIPE ────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use the sk_test_ / pk_test_ pair for testing, sk_live_ / pk_live_ in production.
# NOTE: keep the angle-brackets in the placeholders below — they prevent
# GitHub Push Protection from mistaking these for real secrets.
STRIPE_SECRET_KEY=<paste-your-stripe-secret-key-here>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<paste-your-stripe-publishable-key-here>

# Webhook signing secret — created when you register your webhook endpoint
# at https://dashboard.stripe.com/webhooks (event: checkout.session.completed)
STRIPE_WEBHOOK_SECRET=<paste-your-stripe-webhook-signing-secret-here>

# Public URL of the site — used by Stripe for the success / cancel redirects.
# In dev:  http://localhost:3000
# In prod: https://soukelbey.ca
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── TWILIO (optional) ─────────────────────────────────────────
# Sends an SMS to the restaurant when an order is paid.
# If any of these three values are missing, the SMS step is silently skipped.
# Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=<paste-your-twilio-account-sid-here>
TWILIO_AUTH_TOKEN=<paste-your-twilio-auth-token-here>
TWILIO_PHONE_NUMBER=<+15145550123>              # your Twilio sender number
RESTAURANT_PHONE=+15149162478                   # number that receives SMS notifications
